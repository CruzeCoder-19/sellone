// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (PgBouncer) — runtime queries
  directUrl = env("DIRECT_URL") // direct TCP — prisma migrate only
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  CUSTOMER
  SELLER
  EMPLOYEE
  SALES
  ADMIN
}

enum ProductStatus {
  DRAFT
  ACTIVE
  SOLD_OUT
  ARCHIVED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum PaymentMethod {
  PREPAID
  WOLSELL_CREDIT
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum DiscountType {
  PERCENT
  FLAT
}

enum CreditStatus {
  NONE
  PENDING
  APPROVED
  SUSPENDED
  CLOSED
}

enum CreditTxType {
  CHARGE
  REPAYMENT
  ADJUSTMENT
}

enum CreditTxStatus {
  PENDING_VERIFICATION
  CONFIRMED
  REJECTED
}

enum RepaymentMethod {
  BANK
  UPI
}

enum ShopStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  WON
  LOST
}

// ─────────────────────────────────────────────────────────────────────────────
// NEXTAUTH ADAPTER MODELS
// Field names are fixed — @auth/prisma-adapter expects them verbatim.
// ─────────────────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────────────────────────
// USER & AUTH
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  email          String?   @unique
  phone          String?   @unique
  name           String?
  /// Nullable: phone-OTP-only users will not have a password.
  passwordHash   String?
  /// Required by the NextAuth adapter — set after email verification.
  emailVerified  DateTime?
  phoneVerified  DateTime?
  /// Bumped (same transaction) on every UserRole insert/delete so the jwt
  /// callback can detect stale role arrays in the JWT without a full re-login.
  rolesUpdatedAt DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  /// Soft delete — every query MUST include a `deletedAt: null` filter.
  deletedAt      DateTime?

  // NextAuth adapter back-relations
  accounts Account[]
  sessions Session[]

  // App back-relations
  userRoles       UserRole[]
  addresses       Address[]
  cart            Cart?
  wishlist        Wishlist?
  compareList     CompareList?
  orders          Order[]
  reviews         Review[]
  uploadedAssets  Asset[]
  blogPosts       BlogPost[]
  employeeProfile EmployeeProfile?
  salesProfile    SalesProfile?
  shop            Shop?
  achieverEntries AchieverEntry[]

  // Credit — two relations each to CreditAccount and CreditApplication; all named
  creditAccount        CreditAccount?      @relation("OwnedCreditAccount")
  approvedCredits      CreditAccount[]     @relation("ApprovedCredits")
  creditApplications   CreditApplication[] @relation("SubmittedApplications")
  reviewedApplications CreditApplication[] @relation("ReviewedApplications")
  verifiedTransactions CreditTransaction[] @relation("VerifiedTransactions")

  // Audit trail — nullable FK so logs survive user soft-delete
  auditLogs AuditLog[] @relation("ActorLogs")
}

model UserRole {
  userId String
  role   Role

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// IMPORTANT: any INSERT or DELETE on this table MUST update
  /// User.rolesUpdatedAt in the same transaction.
  /// Enforced in Server Actions — not via Prisma middleware.

  @@id([userId, role])
}

model OtpToken {
  id         String    @id @default(cuid())
  /// The phone number or email address the OTP was sent to.
  identifier String
  /// sha256(rawOtp + process.env.OTP_PEPPER)
  codeHash   String
  /// Incremented on each wrong guess. Reject once attempts >= 5.
  attempts   Int       @default(0)
  expiresAt  DateTime
  /// Set to now() on the first successful verification — prevents replay.
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([identifier])
}

// ─────────────────────────────────────────────────────────────────────────────
// ASSETS — Netlify Blobs reference table
// Domain tables store an assetId FK here instead of raw blob keys so that
// uploads are auditable (who, when, what size) and deletions are traceable.
// ─────────────────────────────────────────────────────────────────────────────

model Asset {
  id           String   @id @default(cuid())
  /// Netlify Blobs store name, e.g. "product-images", "shop-assets", "kyc-docs"
  store        String
  /// The blob key within the store, e.g. "prod_abc/uuid.jpg"
  key          String
  contentType  String
  sizeBytes    Int
  uploadedById String
  createdAt    DateTime @default(now())

  uploadedBy User @relation(fields: [uploadedById], references: [id])

  // Back-relations from models that hold an assetId FK
  productImages           ProductImage[]
  creditApplicationAssets CreditApplicationAsset[]
  // Shop has two FKs → Asset (logo + banner); both sides must be named
  shopLogos               Shop[]                   @relation("ShopLogo")
  shopBanners             Shop[]                   @relation("ShopBanner")
  categories              Category[]
  brands                  Brand[]
  blogPosts               BlogPost[]

  @@unique([store, key])
  @@index([uploadedById])
}

// ─────────────────────────────────────────────────────────────────────────────
// ADDRESSES
// ─────────────────────────────────────────────────────────────────────────────

model Address {
  id         String   @id @default(cuid())
  userId     String
  label      String
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String
  country    String   @default("IN")
  phone      String
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// CATALOG
// ─────────────────────────────────────────────────────────────────────────────

model Category {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  /// Null for top-level categories.
  parentId     String?
  imageAssetId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  parent     Category?         @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children   Category[]        @relation("CategoryHierarchy")
  imageAsset Asset?            @relation(fields: [imageAssetId], references: [id])
  products   ProductCategory[]

  @@index([parentId])
  @@index([imageAssetId])
}

model Brand {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  logoAssetId String?

  logoAsset Asset?    @relation(fields: [logoAssetId], references: [id])
  products  Product[]

  @@index([logoAssetId])
}

model Product {
  id               String        @id @default(cuid())
  slug             String        @unique
  name             String
  description      String?
  sku              String        @unique
  brandId          String?
  /// Null for first-party / platform products; set for marketplace seller listings.
  sellerShopId     String?
  basePriceInPaise Int
  /// Minimum order quantity; tier prices are relative to this baseline.
  moq              Int           @default(1)
  stock            Int           @default(0)
  status           ProductStatus @default(DRAFT)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  /// Soft delete — all queries MUST filter deletedAt: null.
  deletedAt        DateTime?

  brand         Brand?            @relation(fields: [brandId], references: [id])
  sellerShop    Shop?             @relation(fields: [sellerShopId], references: [id])
  categories    ProductCategory[]
  variants      ProductVariant[]
  tierPrices    TierPrice[]
  images        ProductImage[]
  reviews       Review[]
  cartItems     CartItem[]
  wishlistItems WishlistItem[]
  compareItems  CompareItem[]
  orderItems    OrderItem[]

  @@index([sellerShopId])
  @@index([status])
  @@index([brandId])
}

model ProductCategory {
  productId  String
  categoryId String

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  assetId   String
  sortOrder Int      @default(0)
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  asset   Asset   @relation(fields: [assetId], references: [id])

  @@index([productId])
  @@index([assetId])
}

model ProductVariant {
  id                String @id @default(cuid())
  productId         String
  sku               String @unique
  /// Human-readable label, e.g. "Size L / Red"
  name              String
  priceDeltaInPaise Int    @default(0)
  stock             Int    @default(0)

  product       Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems     CartItem[]
  wishlistItems WishlistItem[]
  compareItems  CompareItem[]
  orderItems    OrderItem[]

  @@index([productId])
}

model TierPrice {
  id           String   @id @default(cuid())
  productId    String
  /// Orders of minQty units or more use this price.
  /// Example: (minQty=50, price=₹80), (minQty=100, price=₹70).
  minQty       Int
  priceInPaise Int
  updatedAt    DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Review {
  id        String   @id @default(cuid())
  productId String
  userId    String
  /// Integer 1–5; validated in the application layer.
  rating    Int
  title     String?
  body      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
  @@index([productId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// CART, WISHLIST, COMPARE
// ─────────────────────────────────────────────────────────────────────────────

model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  variantId String?
  quantity  Int
  updatedAt DateTime @updatedAt

  cart    Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  /// NOTE: PostgreSQL UNIQUE treats NULLs as distinct values, so two rows with
  /// (cartId, productId, NULL) are both allowed. Application code must upsert
  /// by querying first — do not rely on conflict detection for variantId=null.
  @@unique([cartId, productId, variantId])
  @@index([productId])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String   @unique
  updatedAt DateTime @updatedAt

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items WishlistItem[]
}

model WishlistItem {
  id         String  @id @default(cuid())
  wishlistId String
  productId  String
  variantId  String?

  wishlist Wishlist        @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  product  Product         @relation(fields: [productId], references: [id])
  variant  ProductVariant? @relation(fields: [variantId], references: [id])

  /// See CartItem note on NULL uniqueness.
  @@unique([wishlistId, productId, variantId])
  @@index([productId])
}

model CompareList {
  id        String   @id @default(cuid())
  userId    String   @unique
  updatedAt DateTime @updatedAt

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CompareItem[]
}

model CompareItem {
  id            String  @id @default(cuid())
  compareListId String
  productId     String
  variantId     String?

  compareList CompareList     @relation(fields: [compareListId], references: [id], onDelete: Cascade)
  product     Product         @relation(fields: [productId], references: [id])
  variant     ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([compareListId, productId, variantId])
  @@index([productId])
}

// ─────────────────────────────────────────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────────────────────────────────────────

model Order {
  id                      String        @id @default(cuid())
  /// Human-readable, e.g. WOL-2026-000123. Generated in application code.
  orderNumber             String        @unique
  customerId              String
  status                  OrderStatus   @default(PENDING)
  paymentMethod           PaymentMethod
  paymentStatus           PaymentStatus @default(PENDING)
  subtotalInPaise         Int
  discountInPaise         Int           @default(0)
  shippingInPaise         Int           @default(0)
  totalInPaise            Int
  couponId                String?
  /// Full address snapshot at order placement. Editing an Address record later
  /// must NOT mutate this field — it is the permanent historical record.
  shippingAddressSnapshot Json
  placedAt                DateTime      @default(now())
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  /// Soft delete — all queries MUST filter deletedAt: null.
  deletedAt               DateTime?

  customer      User                @relation(fields: [customerId], references: [id])
  coupon        Coupon?             @relation(fields: [couponId], references: [id])
  items         OrderItem[]
  creditCharges CreditTransaction[]

  @@index([customerId])
  @@index([status])
  @@index([orderNumber])
  @@index([couponId])
}

model OrderItem {
  id               String  @id @default(cuid())
  orderId          String
  productId        String
  variantId        String?
  sellerShopId     String?
  quantity         Int
  unitPriceInPaise Int
  lineTotalInPaise Int
  /// Snapshot at order time: name, sku, primary image key.
  /// Product edits must NOT mutate this — it is the permanent historical record.
  productSnapshot  Json

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([sellerShopId])
  @@index([productId])
}

model Coupon {
  id                 String       @id @default(cuid())
  code               String       @unique
  discountType       DiscountType
  /// Percentage (0–100) for PERCENT; flat paise amount for FLAT.
  value              Int
  minOrderInPaise    Int          @default(0)
  maxDiscountInPaise Int?
  expiresAt          DateTime?
  usageLimit         Int?
  usedCount          Int          @default(0)
  active             Boolean      @default(true)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  orders Order[]
}

// ─────────────────────────────────────────────────────────────────────────────
// WOLSELL CREDIT (BNPL)
// ─────────────────────────────────────────────────────────────────────────────

model CreditAccount {
  id                 String       @id @default(cuid())
  userId             String       @unique
  status             CreditStatus @default(NONE)
  limitInPaise       Int          @default(0)
  /// availableInPaise = limitInPaise - outstandingInPaise.
  /// Computed in application code — NOT stored — to prevent sync drift.
  outstandingInPaise Int          @default(0)
  approvedAt         DateTime?
  approvedById       String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  user         User                @relation("OwnedCreditAccount", fields: [userId], references: [id], onDelete: Cascade)
  approvedBy   User?               @relation("ApprovedCredits", fields: [approvedById], references: [id])
  transactions CreditTransaction[]

  @@index([userId])
  @@index([approvedById])
}

model CreditApplication {
  id                     String       @id @default(cuid())
  userId                 String
  status                 CreditStatus @default(PENDING)
  submittedAt            DateTime     @default(now())
  reviewedAt             DateTime?
  reviewedById           String?
  legalName              String
  panNumber              String
  gstin                  String?
  businessAddress        String
  monthlyTurnoverInPaise Int?
  rejectionReason        String?

  user       User                     @relation("SubmittedApplications", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User?                    @relation("ReviewedApplications", fields: [reviewedById], references: [id])
  kycAssets  CreditApplicationAsset[]

  @@index([userId])
  @@index([status])
  @@index([reviewedById])
}

/// Join table linking a CreditApplication to its uploaded KYC Assets.
/// Replaces a former String[] array column for proper FK integrity and auditability.
model CreditApplicationAsset {
  applicationId String
  assetId       String

  application CreditApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  asset       Asset             @relation(fields: [assetId], references: [id])

  @@id([applicationId, assetId])
  @@index([assetId])
}

model CreditTransaction {
  id              String           @id @default(cuid())
  creditAccountId String
  type            CreditTxType
  amountInPaise   Int
  /// CHARGE rows are created CONFIRMED.
  /// REPAYMENT rows start PENDING_VERIFICATION until admin verifies the UTR.
  status          CreditTxStatus   @default(CONFIRMED)
  /// Null for CHARGE and ADJUSTMENT types.
  method          RepaymentMethod?
  /// UTR / bank reference number supplied by the customer for repayments.
  utrReference    String?
  /// The Order that triggered this charge row. Null for REPAYMENT / ADJUSTMENT.
  relatedOrderId  String?
  verifiedById    String?
  verifiedAt      DateTime?
  createdAt       DateTime         @default(now())

  creditAccount CreditAccount @relation(fields: [creditAccountId], references: [id], onDelete: Cascade)
  relatedOrder  Order?        @relation(fields: [relatedOrderId], references: [id])
  verifiedBy    User?         @relation("VerifiedTransactions", fields: [verifiedById], references: [id])

  @@index([creditAccountId])
  @@index([status])
  @@index([relatedOrderId])
  @@index([verifiedById])
}

// ─────────────────────────────────────────────────────────────────────────────
// SELLERS
// ─────────────────────────────────────────────────────────────────────────────

model Shop {
  id              String     @id @default(cuid())
  ownerId         String     @unique
  name            String
  slug            String     @unique
  description     String?
  logoAssetId     String?
  bannerAssetId   String?
  gstin           String?
  businessAddress String
  phone           String
  email           String
  status          ShopStatus @default(PENDING)
  verifiedAt      DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  /// Soft delete — all queries MUST filter deletedAt: null.
  deletedAt       DateTime?

  owner       User      @relation(fields: [ownerId], references: [id])
  // Named: two FKs from Shop → Asset
  logoAsset   Asset?    @relation("ShopLogo", fields: [logoAssetId], references: [id])
  bannerAsset Asset?    @relation("ShopBanner", fields: [bannerAssetId], references: [id])
  products    Product[]

  @@index([slug])
  @@index([status])
  @@index([logoAssetId])
  @@index([bannerAssetId])
}

// ─────────────────────────────────────────────────────────────────────────────
// EMPLOYEE / SALES / ACHIEVER
// ─────────────────────────────────────────────────────────────────────────────

model EmployeeProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  employeeCode String   @unique
  department   String?
  joinedAt     DateTime

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  checkIns EmployeeCheckIn[]
}

model EmployeeCheckIn {
  id                String    @id @default(cuid())
  employeeProfileId String
  checkInAt         DateTime
  checkOutAt        DateTime?

  employeeProfile EmployeeProfile @relation(fields: [employeeProfileId], references: [id], onDelete: Cascade)

  @@index([employeeProfileId])
}

model SalesProfile {
  id                   String  @id @default(cuid())
  userId               String  @unique
  region               String?
  monthlyTargetInPaise Int     @default(0)

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  leads SalesLead[]
}

model SalesLead {
  id             String     @id @default(cuid())
  salesProfileId String
  contactName    String
  contactPhone   String?
  contactEmail   String?
  status         LeadStatus @default(NEW)
  notes          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  salesProfile SalesProfile @relation(fields: [salesProfileId], references: [id], onDelete: Cascade)

  @@index([salesProfileId])
  @@index([status])
}

model AchieverEntry {
  id            String   @id @default(cuid())
  userId        String
  /// ISO year-month key, e.g. "2026-04"
  period        String
  metricInPaise Int
  rank          Int?
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// CONTENT & OPS
// ─────────────────────────────────────────────────────────────────────────────

model BlogPost {
  id           String    @id @default(cuid())
  slug         String    @unique
  title        String
  excerpt      String?
  contentMdx   String    @db.Text
  coverAssetId String?
  authorId     String
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  author     User   @relation(fields: [authorId], references: [id])
  coverAsset Asset? @relation(fields: [coverAssetId], references: [id])

  @@index([publishedAt])
  @@index([authorId])
  @@index([coverAssetId])
}

model NewsletterSubscriber {
  id          String    @id @default(cuid())
  email       String    @unique
  confirmedAt DateTime?
  createdAt   DateTime  @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  /// Nullable: system-initiated actions (cron jobs, webhooks) have no actor.
  actorId   String?
  action    String
  entity    String
  entityId  String
  metadata  Json?
  createdAt DateTime @default(now())

  actor User? @relation("ActorLogs", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entity, entityId])
  @@index([actorId])
}
